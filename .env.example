# --- Database ---
# SQLite for zero-config local dev. To use Postgres/Supabase, change provider in
# prisma/schema.prisma to "postgresql" and set this to your connection string.
DATABASE_URL="file:./dev.db"

# --- Auth ---
# Used to sign JWT session tokens. Generate a long random string for production.
AUTH_SECRET="change-me-in-production-use-a-long-random-string"
# Session lifetime in seconds (default 7 days)
SESSION_MAX_AGE="604800"

# --- Seed admin (created by `npm run seed`) ---
SEED_ADMIN_EMAIL="admin@warehouse.local"
SEED_ADMIN_PASSWORD="Admin123!"

# --- Cron / Reports ---
# Secret required to call the protected weekly-report endpoint.
CRON_SECRET="change-me-cron-secret"
# Email the weekly report is sent to (owner). Falls back to admin if unset.
REPORT_OWNER_EMAIL="owner@warehouse.local"

# --- Email (Resend). If unset, emails are logged to the console. ---
RESEND_API_KEY=""
EMAIL_FROM="Warehouse <reports@warehouse.local>"
